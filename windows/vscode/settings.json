    },
    {
      "before": [
        "<leader>",
        "s",
        "c"
      ],
      "commands": [
        "workbench.action.replaceInFiles"
      ]
    },
    {
      "before": [
        "<leader>",
        "w",
        "w"
      ],
      "after": [
        "<C-w>",
        "w"
      ]
    },
    {
      "before": [
        "<leader>",
        "w",
